{
    "compilerOptions": {
        "composite": true,
        "rootDir": "./src",
        "outDir": "./dist",
        "declaration": true,
        "target": "ES2022",
        "module": "ES2022",
        "esModuleInterop": true,
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "sourceMap": false,
        "declarationMap": false,
        "strictFunctionTypes": true,
        "strictNullChecks": true,
        "skipLibCheck": true
    },
    "include": ["src/**/*.ts"],
    "watchOptions": {
        "excludeDirectories": ["./dist"]
    }
}
