# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
# Host port mapped from the dockerized Postgres in demos/docker-compose.yml.
# Container internal port is 5432; do NOT change this for local dev.
DB_PORT=5445
DB_NAME=todo_db
DB_USER=todo_user
DB_PASSWORD=todo_secret

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters for HS256 security.
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-random-secret-of-at-least-32-characters

# Token lifetime in seconds (default 3600 = 1 hour)
JWT_EXPIRES_IN=3600

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
# Point to the host-mapped ClickStack OTLP/HTTP port (container default: 4318).
# The "clickstack" hostname only resolves inside Docker; use localhost for local dev.
OTEL_SERVICE_NAME=todo-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
