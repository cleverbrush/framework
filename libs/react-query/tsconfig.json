{
    "compilerOptions": {
        "composite": true,
        "rootDir": "./src",
        "outDir": "./dist",
        "declaration": true,
        "target": "ES2022",
        "module": "ES2022",
        "esModuleInterop": true,
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "sourceMap": false,
        "declarationMap": false,
        "jsx": "react-jsx",
        "strictNullChecks": true,
        "noImplicitThis": true
    },
    "include": ["src/**/*.ts", "src/**/*.tsx"],
    "exclude": [
        "src/**/*.test.ts",
        "src/**/*.test.tsx",
        "src/**/*.spec.ts",
        "src/**/*.spec.tsx"
    ],
    "references": [
        { "path": "../web/tsconfig.build.json" },
        { "path": "../schema" },
        { "path": "../server/tsconfig.build.json" }
    ],
    "watchOptions": {
        "excludeDirectories": ["./dist"]
    }
}
