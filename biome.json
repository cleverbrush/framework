{
    "$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 80
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "suspicious": {
                "noExplicitAny": "off",
                "noImplicitAnyLet": "off"
            },
            "style": {
                "noNonNullAssertion": "off",
                "useNodejsImportProtocol": "off",
                "useTemplate": "off"
            },
            "complexity": {
                "noBannedTypes": "off",
                "useLiteralKeys": "off"
            }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "jsxQuoteStyle": "double",
            "trailingCommas": "none",
            "semicolons": "always",
            "bracketSpacing": true,
            "arrowParentheses": "asNeeded"
        }
    },
    "files": {
        "includes": [
            "libs/**",
            "website/app/**",
            "website/lib/**",
            "website/*.ts",
            "!website/app/playground/schemaDeclarations.ts"
        ]
    },
    "overrides": [
        {
            "includes": ["libs/react-form/**"],
            "linter": {
                "rules": {
                    "correctness": {
                        "useHookAtTopLevel": "off"
                    }
                }
            }
        },
        {
            "includes": [
                "website/app/page.tsx",
                "website/app/mapper/page.tsx",
                "website/app/layout.tsx",
                "website/app/playground/PlaygroundClient.tsx",
                "website/app/playground/panels/TypePanel.tsx"
            ],
            "linter": {
                "rules": {
                    "security": {
                        "noDangerouslySetInnerHtml": "off"
                    }
                }
            }
        }
    ]
}
