{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**", "*.tsbuildinfo"]
        },
        "clean": {
            "cache": false
        },
        "test:e2e": {
            "dependsOn": ["^build"],
            "cache": false,
            "persistent": false
        }
    }
}
