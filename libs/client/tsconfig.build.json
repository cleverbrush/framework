{
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist",
        "declaration": true,
        "target": "ES2022",
        "lib": ["ES2022", "ESNext.Disposable", "DOM"],
        "module": "ES2022",
        "esModuleInterop": true,
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "sourceMap": false,
        "declarationMap": false,
        "jsx": "react-jsx",
        "strictNullChecks": true,
        "noImplicitThis": true,
        "skipLibCheck": true
    },
    "include": ["src/**/*.ts", "src/**/*.tsx"],
    "exclude": [
        "src/**/*.test.ts",
        "src/**/*.test.tsx",
        "src/**/*.spec.ts",
        "src/**/*.spec.tsx"
    ]
}
