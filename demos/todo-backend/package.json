        "@cleverbrush/env": "0.0.0-beta-20260416104918",
        "@cleverbrush/knex-schema": "0.0.0-beta-20260416104918",
        "@cleverbrush/mapper": "0.0.0-beta-20260416104918",
        "@cleverbrush/schema": "0.0.0-beta-20260416104918",
        "@cleverbrush/schema-json": "0.0.0-beta-20260416104918",
