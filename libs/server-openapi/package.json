{
    "author": "Andrew Zolotukhin <andrew_zol@cleverbrush.com>",
    "bugs": {
        "url": "https://github.com/cleverbrush/framework/issues",
        "email": "andrew_zol@cleverbrush.com"
    },
    "peerDependencies": {
        "@cleverbrush/server": "^3.0.1",
        "@cleverbrush/schema": "^3.0.1",
        "@cleverbrush/schema-json": "^3.0.1",
        "@cleverbrush/auth": "^3.0.1"
    },
    "description": "OpenAPI 3.1 spec generation for @cleverbrush/server — automatic endpoint documentation",
    "files": [
        "dist"
    ],
    "homepage": "https://docs.cleverbrush.com/server-openapi",
    "keywords": [
        "openapi",
        "swagger",
        "server",
        "schema",
        "documentation",
        "cleverbrush"
    ],
    "license": "BSD 3-Clause",
    "main": "./dist/index.js",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "sideEffects": false,
    "name": "@cleverbrush/server-openapi",
    "readme": "https://github.com/cleverbrush/framework/tree/master/libs/server-openapi#readme",
    "repository": {
        "type": "git",
        "url": "github:cleverbrush/framework"
    },
    "scripts": {
        "watch": "tsc --build tsconfig.build.json --watch",
        "build": "tsup && rm -f tsconfig.build.tsbuildinfo && tsc --project tsconfig.build.json --emitDeclarationOnly",
        "clean": "rm -rf dist tsconfig.build.tsbuildinfo"
    },
    "type": "module",
    "types": "./dist/index.d.ts",
    "version": "3.1.0"
}
