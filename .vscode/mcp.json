{
    "servers": {
        "context7": {
            "type": "http",
            "url": "https://mcp.context7.com/mcp"
        },
        "playwright": {
            "command": "npx",
            "args": ["@playwright/mcp", "--headless"]
        },
        "postgres": {
            "command": "docker",
            "args": [
                "run",
                "-i",
                "--rm",
                "--add-host=host.docker.internal:host-gateway",
                "-e",
                "DATABASE_URI",
                "crystaldba/postgres-mcp",
                "--access-mode=unrestricted"
            ],
            "env": {
                "DATABASE_URI": "postgresql://readonly:qwerty123@host.docker.internal:5445/todo_db"
            }
        },
        "clickhouse": {
            "command": "/home/andrew/.local/bin/uv",
            "args": [
                "run",
                "--with",
                "mcp-clickhouse",
                "--python",
                "3.12",
                "mcp-clickhouse"
            ],
            "env": {
                "CLICKHOUSE_HOST": "localhost",
                "CLICKHOUSE_PORT": "8123",
                "CLICKHOUSE_USER": "api",
                "CLICKHOUSE_PASSWORD": "api",
                "CLICKHOUSE_SECURE": "false",
                "CLICKHOUSE_VERIFY": "false"
            }
        }
    }
}