{
    "name": "@cleverbrush/demo-e2e",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "description": "End-to-end test suite for the todo demo (backend + frontend + telemetry stack)",
    "scripts": {
        "test": "vitest --run",
        "test:watch": "vitest",
