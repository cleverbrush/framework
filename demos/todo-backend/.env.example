# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=todo_db
DB_USER=todo_user
DB_PASSWORD=todo_secret

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters for HS256 security.
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-random-secret-of-at-least-32-characters

# Token lifetime in seconds (default 3600 = 1 hour)
JWT_EXPIRES_IN=3600

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ── pgAdmin ───────────────────────────────────────────────────────────────────
# Browse the database at http://localhost:8110
# PGADMIN_EMAIL=admin@todo.local
# PGADMIN_PASSWORD=admin

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
