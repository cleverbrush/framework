        "playwright:install": "playwright install chromium"
    },
    "dependencies": {
        "pg": "^8.13.3",
        "playwright": "^1.49.1",
        "ws": "^8.18.0"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "@types/pg": "^8.11.10",
        "@types/ws": "^8.5.13",
        "typescript": "^6.0.2",
        "vitest": "^4.1.2"
    }
}
