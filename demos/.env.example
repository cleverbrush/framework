# ─────────────────────────────────────────────────────────────────
# Todo App Demo — Environment Variables
# Copy this file to .env and fill in the required values
# ─────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_DB=todo_db
POSTGRES_USER=todo_user
POSTGRES_PASSWORD=todo_secret

# ── Backend DB connection (uses the same values above) ────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=todo_db
DB_USER=todo_user
DB_PASSWORD=todo_secret

# ── Backend ───────────────────────────────────────────────────────
# Generate a secure secret (must be ≥32 chars): node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-in-production-min32chars!
JWT_EXPIRES_IN=3600

# ── Google OAuth (optional — enables Google Sign-In) ─────────────
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized JavaScript origins: http://localhost:5173
# Authorized redirect URIs: http://localhost:5173
GOOGLE_CLIENT_ID=

# ── Ports ─────────────────────────────────────────────────────────
APP_PORT=3000
FRONTEND_PORT=5173
SWAGGER_PORT=8090
# ClickStack UI port. Container's internal UI port is set to this same
# value via HYPERDX_APP_PORT, so host and container always match — this
# is required because the UI generates self-referential URLs using its
# internal port.
CLICKSTACK_PORT=8091

