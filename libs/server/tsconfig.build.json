{
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist",
        "declaration": true,
        "target": "ES2022",
        "lib": ["ES2022", "ESNext.Disposable"],
        "module": "ES2022",
        "esModuleInterop": true,
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "sourceMap": false,
        "declarationMap": false,
        "ignoreDeprecations": "6.0",
        "types": ["node"]
    },
    "include": ["src/**/*.ts"],
    "exclude": ["src/**/*.test.ts"]
}
